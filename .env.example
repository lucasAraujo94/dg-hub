# App
NODE_ENV=development
PORT=3001

# Database (SQL Server)
# Example: sqlserver://user:pass@localhost:1433;database=dg_hub;encrypt=true;trustServerCertificate=true
DATABASE_URL=sqlserver://USER:PASS@localhost:1433;database=dg_hub;encrypt=true;trustServerCertificate=true
JWT_SECRET=generate-a-strong-secret

# OAuth / Login
VITE_APP_ID=dg-hub-dev
OAUTH_SERVER_URL=http://localhost:4000
VITE_OAUTH_PORTAL_URL=http://localhost:4000
OWNER_OPEN_ID=local:admin@example.com
OWNER_EMAIL=
# Fallback Google OAuth (opcional)
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Ajuste o caminho de callback para o ambiente (ex.: /dg-games/auth/google/callback no GitHub Pages)
VITE_GOOGLE_REDIRECT_PATH=/auth/google/callback

# Forge / Maps
BUILT_IN_FORGE_API_URL=https://forge.butterfly-effect.dev
BUILT_IN_FORGE_API_KEY=your-forge-api-key
VITE_FRONTEND_FORGE_API_URL=https://forge.butterfly-effect.dev
VITE_FRONTEND_FORGE_API_KEY=your-google-maps-key

# Analytics (optional)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Mercado Pago
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
